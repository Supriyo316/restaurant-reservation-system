<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reservation Successful - Supriyo's Restaurant</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@200;300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <section class="notFound">
    <div class="container">
      <img src="/images/sandwich.png" alt="Reservation Successful" />
      <h1>RESERVATION CONFIRMED!</h1>
      <p>Thank you for choosing Supriyo's Restaurant. Redirecting to home in <span id="countdown">10</span> seconds...</p>
      <a href="/">Back to Home <span>→</span></a>
    </div>
  </section>
  <script>
    let countdown = 10;
    const countdownEl = document.getElementById('countdown');
    const interval = setInterval(() => {
      countdown--;
      countdownEl.textContent = countdown;
      if (countdown <= 0) {
        clearInterval(interval);
        window.location.href = '/';
      }
    }, 1000);
  </script>
</body>
</html>